# Copy to .env (gitignored). The backend loads this at startup.

# API key for your provider — set the one matching RAG_PROVIDER:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Default provider/model (changeable later in the app's settings):
# RAG_PROVIDER=google_genai        # anthropic | openai | google_genai
# RAG_MODEL=gemini-2.5-flash
